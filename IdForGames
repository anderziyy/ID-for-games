CopyBtn.MouseButton1Click:Connect(function()
    if InputBox.Text ~= "" then
        StarterGui:SetCore("Clipboard", InputBox.Text)
    end
end)

GenBtn.MouseButton1Click:Connect(function()
    local FoundId = nil
    local Success, Result = pcall(function() return game.PlaceId end)
    if Success and Result and Result > 0 then FoundId = Result end
    if not FoundId then
        local function Scan(Obj)
            for _, Desc in ipairs(Obj:GetDescendants()) do
                if Desc:IsA("NumberValue") or Desc:IsA("IntValue") or Desc:IsA("StringValue") then
                    local N = string.lower(Desc.Name)
                    if string.find(N,"placeid") or string.find(N,"gameid") or string.find(N,"universeid") then
                        local V = tonumber(Desc.Value) or Desc.Value
                        if type(V)=="number" and V>0 then FoundId=V; break end
                    end
                end
                if Desc:IsA("RemoteEvent") or Desc:IsA("RemoteFunction") then
                    local N = string.lower(Desc.Name)
                    if string.find(N,"placeid") or string.find(N,"gameid") then
                        local M = Desc:GetAttributes()
                        for K,V in pairs(M) do
                            if string.lower(K):find("id") and tonumber(V) then FoundId=tonumber(V); break end
                        end
                    end
                end
                Scan(Desc)
                if FoundId then break end
            end
        end
        Scan(game)
    end
    if not FoundId then FoundId = game.PlaceId end
    InputBox.Text = tostring(FoundId)
end)
